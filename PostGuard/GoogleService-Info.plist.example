<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- セットアップ手順:
	     1. Firebase コンソールで iOS アプリ「com.postguard.app」を登録
	     2. ダウンロードした GoogleService-Info.plist をこのフォルダに
	        「GoogleService-Info.plist」という名前で配置（このファイルは .example）
	     3. CLIENT_ID / REVERSED_CLIENT_ID を PostGuard/Info.plist にも転記
	     ※ プレースホルダ（GOOGLE_APP_ID が "0:" 始まり）のままだと
	        FirebaseBootstrap は configure をスキップする -->
	<key>API_KEY</key>
	<string>YOUR_API_KEY</string>
	<key>GCM_SENDER_ID</key>
	<string>000000000000</string>
	<key>PLIST_VERSION</key>
	<string>1</string>
	<key>BUNDLE_ID</key>
	<string>com.postguard.app</string>
	<key>PROJECT_ID</key>
	<string>your-project-id</string>
	<key>STORAGE_BUCKET</key>
	<string>your-project-id.firebasestorage.app</string>
	<key>GOOGLE_APP_ID</key>
	<string>0:000000000000:ios:0000000000000000000000</string>
	<key>CLIENT_ID</key>
	<string>YOUR_CLIENT_ID.apps.googleusercontent.com</string>
	<key>REVERSED_CLIENT_ID</key>
	<string>com.googleusercontent.apps.YOUR_CLIENT_ID</string>
	<key>IS_ADS_ENABLED</key>
	<false/>
	<key>IS_ANALYTICS_ENABLED</key>
	<false/>
	<key>IS_APPINVITE_ENABLED</key>
	<true/>
	<key>IS_GCM_ENABLED</key>
	<true/>
	<key>IS_SIGNIN_ENABLED</key>
	<true/>
</dict>
</plist>
