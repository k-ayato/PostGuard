rules_version = '2';

// PostGuard Firestore Security Rules
// Firebaseコンソール > Firestore Database > ルール にデプロイしてください。
//
// users/{uid}: 使用量記録。本人のみ読み書き可。
// usageCount は「月跨ぎリセット」または「単調増加」のみ許可し、
// クライアントが回数を減らす改ざんを防ぐ。
service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{uid} {
      allow read, delete: if request.auth != null && request.auth.uid == uid;

      allow create: if request.auth != null && request.auth.uid == uid
        && request.resource.data.usageCount is int
        && request.resource.data.usageCount >= 0
        && request.resource.data.usageMonth is string;

      allow update: if request.auth != null && request.auth.uid == uid
        && request.resource.data.usageCount is int
        && request.resource.data.usageCount >= 0
        && (
          // 月が変わった場合はリセットを許可
          request.resource.data.usageMonth != resource.data.usageMonth
          // 同月内は増加のみ許可
          || request.resource.data.usageCount >= resource.data.usageCount
        );
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
